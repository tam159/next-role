# LM Studio example: OPENAI_API_BASE=http://host.docker.internal:1234/v1
# Azure OpenAI example: OPENAI_API_BASE=https://company-region.openai.azure.com/openai/v1/
OPENAI_API_BASE=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=

POSTGRES_USER=next-role
POSTGRES_PASSWORD=
POSTGRES_DB=next-role
POSTGRES_LOCAL_PORT=5449
POSTGRES_URI=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_LOCAL_PORT}/${POSTGRES_DB}

REDIS_LOCAL_PORT=6376

LLAMA_CLOUD_API_KEY=

LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY= # gitleaks:allow
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=next-role

LANGGRAPH_LOCAL_PORT=8129

FRONTEND_LOCAL_PORT=3007
NEXT_PUBLIC_LANGGRAPH_DEPLOYMENT_URL=http://127.0.0.1:${LANGGRAPH_LOCAL_PORT}
NEXT_PUBLIC_LANGGRAPH_ASSISTANT_ID=career_agent
NEXT_PUBLIC_LANGSMITH_API_KEY=""

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# --- Multi-user auth (opt-in) ---
# Unset/false = today's zero-login single-user mode. true = require login
# (Google and/or email+password via Better Auth, hosted inside the frontend).
AUTH_ENABLED=false
# Session/token signing secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Optional Google sign-in (email/password works without it). Create an OAuth
# client at https://console.cloud.google.com/ with redirect URI
# http://localhost:${FRONTEND_LOCAL_PORT}/api/auth/callback/google
AUTH_GOOGLE_ENABLED=false
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
# One-time schema setup when first enabling auth (Better Auth owns its own
# tables in the shared Postgres, separate from backend/storage/migrations):
#   AUTH_DATABASE_URL="postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:<POSTGRES_LOCAL_PORT>/<POSTGRES_DB>" \
#   BETTER_AUTH_SECRET=<same secret> \
#     pnpm --dir frontend dlx @better-auth/cli@latest migrate --config src/lib/auth/server.ts
#
# Backend enforcement — set BOTH of these together with AUTH_ENABLED=true
# (frontend login without backend enforcement is fine for trying the UI, but
# provides no isolation; backend enforcement without frontend tokens 401s
# every request):
#   LANGGRAPH_AUTH={"path": "/deps/next-role/backend/agents/auth.py:auth", "disable_studio_auth": true}
# In cloud deployments additionally set REQUIRE_AUTH=true — the backend then
# refuses to boot if LANGGRAPH_AUTH is missing:
#   REQUIRE_AUTH=true
#
# Cloud hardening checklist (beyond enabling auth):
#   - Serve everything over HTTPS; set BETTER_AUTH_URL / AUTH_JWT_ISSUER /
#     AUTH_JWT_AUDIENCE to the public https origin, and AUTH_JWKS_URL to the
#     in-network frontend URL the backend can reach.
#   - Pin CORS to the frontend origin (default is "*", fine only for local):
#       CORS_ALLOW_ORIGINS=https://your-frontend.example
#   - Block or disable the unauthenticated meta routes at the ingress —
#     /metrics leaks thread/run counts; also /docs, /openapi.json, /info.
#   - MCP (/mcp) and A2A (/a2a) are authentication-gated only (no per-resource
#     authz yet) — disable them until audited by extending LANGGRAPH_HTTP with
#     "disable_mcp": true / "disable_a2a": true.
#   - Do NOT set LANGSMITH_LANGGRAPH_API_VARIANT=local_dev in production (it
#     opens a Studio noop-auth backdoor); disable_studio_auth:true above closes
#     the header-based one.
#   - Ensure the reverse proxy never forwards a client-controlled root_path
#     (the in-process "/noauth" loopback bypass must stay internal-only).

# --- Object storage (binary artifacts: uploads + rendered PDFs) ---
# Local dev runs SeaweedFS (S3-compatible) via docker compose; in the cloud,
# point these at S3 / GCS / Azure or any S3-compatible store instead.
# NOTE: AWS_* above is reserved for Bedrock models — never point it at the
# local emulator. The object store reads only OBJECT_STORE_*.
OBJECT_STORE_LOCAL_PORT=8334
OBJECT_STORE_UI_LOCAL_PORT=8889
OBJECT_STORE_ENDPOINT=http://localhost:${OBJECT_STORE_LOCAL_PORT}
OBJECT_STORE_BUCKET=next-role-artifacts
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_ACCESS_KEY=dev-access-key
OBJECT_STORE_SECRET_KEY=dev-secret-key # gitleaks:allow
OBJECT_STORE_FORCE_PATH_STYLE=true
